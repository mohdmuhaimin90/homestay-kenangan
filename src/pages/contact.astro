---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

const WHATSAPP_NUMBER = '60199144505';
const WHATSAPP_MESSAGE = encodeURIComponent("Hi I'm interested in booking your homestay.");
const WHATSAPP_URL = `https://wa.me/${WHATSAPP_NUMBER}?text=${WHATSAPP_MESSAGE}`;
const PHONE_NUMBER = '+60 19-914 4505';
const EMAIL = 'kenangan.homestay@gmail.com';
const ADDRESS_KEMAMAN = 'Kemaman, Terengganu, Malaysia';
const ADDRESS_KT = 'Kuala Terengganu, Terengganu, Malaysia';
---

<Layout
  title="Contact Us"
  description="Contact Homestay Kenangan. Book via WhatsApp for the best rates and instant confirmation. Two locations in Kemaman and Kuala Terengganu."
  canonical="https://homestay-kenangan.vercel.app/contact"
  ogType="article"
>
  <Header />
  <main>
    <section class="pt-32 pb-16 bg-gradient-to-br from-gray-900 to-gray-800 text-white">
      <div class="container-custom text-center">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold mb-4">Contact Us</h1>
        <p class="text-lg text-gray-300 max-w-2xl mx-auto">
          Get in touch with us. We are here to help with your booking and inquiries.
        </p>
      </div>
    </section>

    <section class="section-padding bg-white dark:bg-gray-900" aria-label="Contact information">
      <div class="container-custom">
        <div class="grid lg:grid-cols-2 gap-12">
          <!-- Left: Contact Details -->
          <div class="space-y-8">
            <div>
              <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">Get In Touch</h2>
              <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
                Ready to book or have a question? Reach out to us directly through WhatsApp for
                the fastest response. We have two locations to choose from.
              </p>
            </div>

            <div class="space-y-6">
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-xl bg-primary/10 dark:bg-primary/20 flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary" aria-hidden="true">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-gray-900 dark:text-white">WhatsApp</h3>
                  <p class="text-gray-600 dark:text-gray-400">{PHONE_NUMBER}</p>
                  <a href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer" class="text-primary hover:text-primary-600 text-sm font-medium transition-colors" aria-label="Send WhatsApp message">Send us a message</a>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-xl bg-primary/10 dark:bg-primary/20 flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary" aria-hidden="true">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                    <polyline points="22,6 12,13 2,6"/>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-gray-900 dark:text-white">Email</h3>
                  <p class="text-gray-600 dark:text-gray-400">{EMAIL}</p>
                  <a href={`mailto:${EMAIL}`} class="text-primary hover:text-primary-600 text-sm font-medium transition-colors">Send us an email</a>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-xl bg-primary/10 dark:bg-primary/20 flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary" aria-hidden="true">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-gray-900 dark:text-white">Locations</h3>
                  <p class="text-gray-600 dark:text-gray-400 text-sm">{ADDRESS_KEMAMAN}</p>
                  <p class="text-gray-600 dark:text-gray-400 text-sm mt-1">{ADDRESS_KT}</p>
                </div>
              </div>
            </div>

            <!-- Price Info -->
            <div class="grid grid-cols-2 sm:grid-cols-5 gap-3">
              <div class="bg-gray-50 dark:bg-gray-800 rounded-xl p-4 text-center">
                <p class="text-2xl font-bold text-primary">RM 180</p>
                <p class="text-xs text-gray-500 dark:text-gray-400">Price/night</p>
              </div>
              <div class="bg-gray-50 dark:bg-gray-800 rounded-xl p-4 text-center">
                <p class="text-2xl font-bold text-primary">RM 350</p>
                <p class="text-xs text-gray-500 dark:text-gray-400">Max/night</p>
              </div>
              <div class="bg-gray-50 dark:bg-gray-800 rounded-xl p-4 text-center">
                <p class="text-2xl font-bold text-primary">2PM</p>
                <p class="text-xs text-gray-500 dark:text-gray-400">Check-in</p>
              </div>
              <div class="bg-gray-50 dark:bg-gray-800 rounded-xl p-4 text-center">
                <p class="text-2xl font-bold text-primary">12PM</p>
                <p class="text-xs text-gray-500 dark:text-gray-400">Check-out</p>
              </div>
              <div class="bg-gray-50 dark:bg-gray-800 rounded-xl p-4 text-center">
                <p class="text-2xl font-bold text-primary">2</p>
                <p class="text-xs text-gray-500 dark:text-gray-400">Locations</p>
              </div>
            </div>
          </div>

          <!-- Right: CTA -->
          <div class="space-y-6">
            <div class="bg-gradient-to-br from-primary to-primary-700 rounded-2xl p-8 text-center text-white">
              <h3 class="text-2xl font-bold mb-3">Book Directly via WhatsApp</h3>
              <p class="text-white/80 mb-6 text-sm leading-relaxed">
                Get the best rates and instant confirmation when you book through WhatsApp.
                Choose from our Kemaman or Kuala Terengganu location.
              </p>
              <a
                href={WHATSAPP_URL}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-6 py-3 bg-white text-primary font-bold rounded-full hover:shadow-2xl hover:scale-105 transition-all"
                aria-label="Book now via WhatsApp"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                </svg>
                Book via WhatsApp
              </a>
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div class="card text-center">
                <h4 class="font-semibold text-gray-900 dark:text-white mb-2 text-sm">Kemaman</h4>
                <a href="https://maps.app.goo.gl/KyBmg1iwgqLiSsha9" target="_blank" rel="noopener noreferrer" class="text-primary hover:text-primary-600 text-xs font-medium transition-colors">View on Maps</a>
              </div>
              <div class="card text-center">
                <h4 class="font-semibold text-gray-900 dark:text-white mb-2 text-sm">Kuala Terengganu</h4>
                <a href="https://maps.app.goo.gl/SCBDByiRjyYQefny6" target="_blank" rel="noopener noreferrer" class="text-primary hover:text-primary-600 text-xs font-medium transition-colors">View on Maps</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <WhatsAppButton />
</Layout>
