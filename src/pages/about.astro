---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

const highlights = [
  'Spacious Rooms', 'Clean Environment', 'Family Friendly', 'Affordable Price',
  'Strategic Location', 'Self Check-in', 'Free Parking', 'High-speed WiFi',
  'Full Kitchen', 'Smart TV', 'Air Conditioning', '24/7 Hot Water',
];
---

<Layout
  title="About Us"
  description="Learn more about Homestay Kenangan. Two convenient locations in Kemaman and Kuala Terengganu. Clean, comfortable, and affordable family homestays."
  canonical="https://your-homestay.vercel.app/about"
  ogType="article"
>
  <Header />
  <main>
    <section class="pt-32 pb-16 bg-gradient-to-br from-gray-900 to-gray-800 text-white">
      <div class="container-custom text-center">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold mb-4">About Us</h1>
        <p class="text-lg text-gray-300 max-w-2xl mx-auto">
          Discover Homestay Kenangan and why families love staying with us at both our locations.
        </p>
      </div>
    </section>

    <!-- Story -->
    <section class="section-padding bg-white dark:bg-gray-900">
      <div class="container-custom">
        <div class="text-center mb-12">
          <span class="text-primary font-semibold text-sm tracking-wider uppercase">Our Story</span>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4">
            Providing Comfortable Stays Across Terengganu
          </h2>
          <p class="text-gray-600 dark:text-gray-400 max-w-3xl mx-auto leading-relaxed">
            Homestay Kenangan was founded with a simple mission: to provide travelers and families
            with clean, comfortable, and affordable home away from home. With two convenient locations
            in Kemaman and Kuala Terengganu, we offer modern amenities combined with warm Malaysian
            hospitality. Every detail, from our quality bedding to our well-equipped kitchens, is
            carefully chosen to ensure you have a memorable stay.
          </p>
        </div>

        <!-- Two Homestays Detail -->
        <div class="grid md:grid-cols-2 gap-8">
          <div class="card overflow-hidden p-0">
            <div class="aspect-[16/9] overflow-hidden">
              <img src="/images/kemaman/Living Hall.jpg" alt="Homestay Kenangan Kemaman living hall" class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Homestay Kenangan Kemaman</h3>
              <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
                Located in the heart of Kemaman, this cozy homestay offers a peaceful retreat with
                easy access to local amenities, beaches, and dining options. Features 2 bedrooms,
                1 bathroom, and 1 toilet. Perfect for small families.
              </p>
            </div>
          </div>
          <div class="card overflow-hidden p-0">
            <div class="aspect-[16/9] overflow-hidden">
              <img src="/images/kuala-terengganu/living room 1.jpg" alt="Homestay Kenangan Kuala Terengganu living room" class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Homestay Kenangan Kuala Terengganu</h3>
              <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
                A spacious homestay in the vibrant city of Kuala Terengganu. Features 4 bedrooms and
                4 bathrooms. Close to attractions like Batu Buruk Beach, Crystal Mosque, and Pasar
                Payang. Ideal for large families and groups.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Highlights -->
    <section class="section-padding bg-gray-50 dark:bg-gray-800/50">
      <div class="container-custom">
        <div class="text-center mb-12">
          <h2 class="section-title">Why Choose Us</h2>
          <p class="section-subtitle">We go above and beyond to make your stay exceptional.</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
          {highlights.map((item) => (
            <div class="flex items-center gap-3 p-4 rounded-xl bg-white dark:bg-gray-800 shadow-soft hover:shadow-hover transition-all group">
              <div class="w-10 h-10 rounded-lg bg-primary/10 dark:bg-primary/20 flex items-center justify-center text-primary group-hover:scale-110 transition-transform flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              </div>
              <span class="text-sm font-medium text-gray-700 dark:text-gray-300">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section-padding bg-gradient-to-br from-primary to-primary-700">
      <div class="container-custom text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Ready to Experience Comfort?</h2>
        <p class="text-lg text-white/80 max-w-xl mx-auto mb-8">
          Book your stay now and enjoy a relaxing family vacation at either location.
        </p>
        <a
          href="https://wa.me/60199144505?text=Hi%20I'm%20interested%20in%20booking%20your%20homestay."
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-8 py-4 bg-white text-primary font-bold text-lg rounded-full hover:shadow-2xl hover:scale-105 transition-all"
          aria-label="Book now via WhatsApp"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
          Book via WhatsApp
        </a>
      </div>
    </section>
  </main>
  <Footer />
  <WhatsAppButton />
</Layout>
