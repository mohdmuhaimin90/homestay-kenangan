---
const locations = [
  {
    name: 'Homestay Kenangan Kemaman',
    attractions: [
      { name: 'Kemaman Town Centre', distance: '5 min', description: 'Explore the local town with markets, shops, and authentic Terengganu cuisine.', icon: 'building-2' },
      { name: 'Kemaman Beach', distance: '10 min', description: 'Beautiful coastline perfect for relaxing walks, sunset views, and family picnics.', icon: 'umbrella' },
      { name: 'Local Restaurants', distance: '3 min', description: 'Enjoy authentic Malaysian dishes at nearby eateries and seafood restaurants.', icon: 'utensils' },
      { name: 'Kerteh Airport', distance: '25 min', description: 'Convenient access to and from the airport for hassle-free travel.', icon: 'plane' },
    ],
  },
  {
    name: 'Homestay Kenangan Kuala Terengganu',
    attractions: [
      { name: 'Kuala Terengganu Town', distance: '5 min', description: 'Vibrant city center with traditional markets, modern shops, and cultural landmarks.', icon: 'building-2' },
      { name: 'Batu Buruk Beach', distance: '8 min', description: 'Popular beach with golden sand, perfect for family outings and sunset photography.', icon: 'umbrella' },
      { name: 'Crystal Mosque', distance: '10 min', description: 'Stunning crystal-built mosque on an island, a must-visit architectural icon.', icon: 'mosque' },
      { name: 'Pasar Payang', distance: '7 min', description: 'Traditional market offering local handicrafts, batik, fresh produce, and souvenirs.', icon: 'store' },
      { name: 'Terengganu State Museum', distance: '12 min', description: 'One of Southeast Asia\'s largest museums showcasing rich local history and culture.', icon: 'landmark' },
      { name: 'Sultan Mahmud Airport', distance: '15 min', description: 'Easy airport access for arriving and departing guests.', icon: 'plane' },
    ],
  },
];
---

<section id="nearby-attractions" class="section-padding bg-white dark:bg-gray-900" aria-label="Nearby attractions">
  <div class="container-custom">
    <div class="text-center mb-12">
      <span class="text-primary font-semibold text-sm tracking-wider uppercase">Explore</span>
      <h2 class="section-title">Nearby Attractions</h2>
      <p class="section-subtitle">
        Discover popular attractions near both our homestay locations.
      </p>
    </div>

    {locations.map((loc) => (
      <div class="mb-12 last:mb-0">
        <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-6 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary" aria-hidden="true">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          {loc.name}
        </h3>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {loc.attractions.map((attraction) => (
            <div class="card group hover:-translate-y-1 cursor-default" itemscope itemtype="https://schema.org/TouristAttraction">
              <div class="w-10 h-10 rounded-xl bg-primary/10 dark:bg-primary/20 flex items-center justify-center mb-3 group-hover:scale-110 group-hover:bg-primary group-hover:text-white transition-all duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary group-hover:text-white transition-colors" aria-hidden="true">
                  <circle cx="12" cy="12" r="10"/>
                  <path d="M12 16v-4"/>
                  <path d="M12 8h.01"/>
                </svg>
              </div>
              <div class="flex items-center justify-between mb-2">
                <h4 class="font-semibold text-gray-900 dark:text-white text-sm" itemprop="name">{attraction.name}</h4>
                <span class="text-xs font-semibold text-primary bg-primary/10 dark:bg-primary/20 px-2.5 py-1 rounded-full">{attraction.distance}</span>
              </div>
              <p class="text-xs text-gray-600 dark:text-gray-400 leading-relaxed" itemprop="description">{attraction.description}</p>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
